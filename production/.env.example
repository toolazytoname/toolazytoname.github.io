# Copy this file to .env and fill in real values.
# NEVER commit the real .env file.

# Primary LLM — Google Gemini (used by default in /api/chat)
GEMINI_API_KEY=your_gemini_api_key_here

# Fallback LLM — DeepSeek (used if Gemini fails or rate-limits)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: override the site URL used in sitemap + RSS
PUBLIC_SITE_URL=https://weichao.ren