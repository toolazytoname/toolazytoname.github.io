# Copy this file to .env and fill in real values.
# NEVER commit the real .env file.

# Primary LLM — Agnes-2.0-flash (OpenAI-compatible, used by default in /api/chat)
# Get a free key at https://wiki.agnes-ai.com/en/docs/tokenplan.md
AGNES_API_KEY=your_agnes_api_key_here

# Fallback LLM — DeepSeek (used if Agnes fails or rate-limits)
# Optional — leave blank to skip the fallback and rely on static answers.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: override the site URL used in sitemap + RSS
PUBLIC_SITE_URL=https://weichao.ren
