---
import type { Memory } from '@data/memories';

interface Props {
  memory: Memory;
  index: number;
}

const { memory, index } = Astro.props;
---

<article
  class="memory-card reveal"
  style={`--accent: ${memory.color};`}
  data-memory-id={memory.id}
>
  <div class="memory-card__photo">
    <img src={memory.photo} alt={memory.title} loading="lazy" />
    <span class="memory-card__icon">{memory.icon}</span>
  </div>
  <div class="memory-card__body">
    <p class="memory-card__date eyebrow">{memory.date}</p>
    <h3 class="memory-card__title serif">{memory.title}</h3>
    <p class="memory-card__desc">
      {memory.desc.split('\n\n')[0]}
    </p>
    <div class="memory-card__tags">
      {memory.tags.slice(0, 3).map((t) => (
        <span class="memory-card__tag">#{t}</span>
      ))}
    </div>
  </div>
  <span class="memory-card__index" aria-hidden="true">0{index + 1}</span>
</article>

<style>
  .memory-card {
    position: relative;
    background: var(--color-ivory);
    border: 1px solid var(--color-warm-border);
    border-radius: var(--r-xl);
    overflow: hidden;
    transition: transform var(--t-base) var(--ease-out),
      box-shadow var(--t-base) var(--ease-out);
  }
  .memory-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 12px rgba(20, 20, 19, 0.06);
  }
  .memory-card__photo {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--color-warm-sand);
    overflow: hidden;
  }
  .memory-card__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms var(--ease-out);
  }
  .memory-card:hover .memory-card__photo img {
    transform: scale(1.06);
  }
  .memory-card__icon {
    position: absolute;
    bottom: var(--s-3);
    right: var(--s-3);
    font-size: 32px;
    background: rgba(20, 20, 19, 0.7);
    backdrop-filter: blur(8px);
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
  }
  .memory-card__body {
    padding: var(--s-6);
  }
  .memory-card__date {
    color: var(--accent);
    margin: 0 0 var(--s-2);
    font-size: 11px;
  }
  .memory-card__title {
    font-size: 22px;
    line-height: 1.2;
    margin: 0 0 var(--s-3);
    color: var(--color-warm-text);
  }
  .memory-card__desc {
    color: var(--color-warm-text-muted);
    font-size: 15px;
    line-height: 1.6;
    margin: 0 0 var(--s-4);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .memory-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .memory-card__tag {
    font-size: 11px;
    color: var(--color-warm-text-dim);
    background: var(--color-warm-sand);
    padding: 2px 8px;
    border-radius: 980px;
  }
  .memory-card__index {
    position: absolute;
    top: var(--s-3);
    left: var(--s-3);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ivory);
    background: rgba(20, 20, 19, 0.6);
    padding: 4px 8px;
    border-radius: 4px;
    backdrop-filter: blur(8px);
  }
</style>