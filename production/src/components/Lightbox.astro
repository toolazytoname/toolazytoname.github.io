---
import type { Memory } from '@data/memories';

interface Props {
  memory: Memory;
}

const { memory } = Astro.props;

// Lock body scroll while open. Activated on the next tick via [data-lightbox] is-open.
---

<div
  class="lightbox"
  role="dialog"
  aria-modal="true"
  aria-labelledby="lightbox-title"
  data-lightbox
>
  <button class="lightbox__scrim" aria-label="关闭" data-lightbox-close></button>

  <div class="lightbox__panel" data-lightbox-panel>
    <button
      type="button"
      class="lightbox__close"
      aria-label="关闭"
      data-lightbox-close
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <div class="lightbox__photo" style={`background: linear-gradient(135deg, ${memory.color}33, ${memory.color}11);`}>
      <img src={memory.photo} alt={memory.title} loading="lazy" />
      <span class="lightbox__icon">{memory.icon}</span>
    </div>

    <div class="lightbox__body">
      <p class="eyebrow" style={`color: ${memory.color};`}>{memory.date}</p>
      <h2 id="lightbox-title" class="lightbox__title serif">{memory.title}</h2>
      <div class="lightbox__desc">
        {memory.desc.split('\n\n').map((para) => <p>{para}</p>)}
      </div>
      <div class="lightbox__tags">
        {memory.tags.map((t) => <span class="lightbox__tag">#{t}</span>)}
      </div>
    </div>
  </div>
</div>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: var(--z-lightbox);
    display: grid;
    place-items: center;
    padding: var(--s-4);
    animation: lb-in 280ms var(--ease-out);
  }
  @keyframes lb-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  .lightbox__scrim {
    position: absolute;
    inset: 0;
    background: rgba(20, 20, 19, 0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: none;
    cursor: pointer;
  }
  .lightbox__panel {
    position: relative;
    width: min(960px, 100%);
    max-height: 90vh;
    overflow: auto;
    background: var(--color-ivory);
    border-radius: var(--r-2xl);
    display: grid;
    grid-template-columns: 1fr 1fr;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.25);
    animation: lb-panel-in 320ms var(--ease-out);
  }
  @keyframes lb-panel-in {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  .lightbox__close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(20, 20, 19, 0.6);
    color: var(--color-ivory);
    display: grid;
    place-items: center;
    z-index: 2;
    transition: background 200ms;
  }
  .lightbox__close:hover {
    background: rgba(20, 20, 19, 0.85);
  }
  .lightbox__photo {
    position: relative;
    min-height: 280px;
    overflow: hidden;
    border-radius: var(--r-2xl) 0 0 var(--r-2xl);
    display: grid;
    place-items: center;
  }
  .lightbox__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
  }
  .lightbox__icon {
    position: relative;
    font-size: 96px;
    filter: drop-shadow(0 8px 24px rgba(0,0,0,0.3));
    z-index: 1;
  }
  .lightbox__body {
    padding: var(--s-10) var(--s-8);
  }
  .lightbox__title {
    font-size: 32px;
    margin: var(--s-2) 0 var(--s-5);
    color: var(--color-warm-text);
    line-height: 1.15;
  }
  .lightbox__desc p {
    color: var(--color-warm-text-muted);
    line-height: 1.7;
    margin: 0 0 var(--s-3);
    font-size: 16px;
    white-space: pre-line;
  }
  .lightbox__tags {
    margin-top: var(--s-6);
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
  }
  .lightbox__tag {
    font-size: 12px;
    padding: 4px 10px;
    border-radius: 980px;
    background: var(--color-warm-sand);
    color: var(--color-warm-text-muted);
  }

  @media (max-width: 768px) {
    .lightbox__panel {
      grid-template-columns: 1fr;
      max-height: 95vh;
    }
    .lightbox__photo {
      min-height: 200px;
      border-radius: var(--r-2xl) var(--r-2xl) 0 0;
    }
    .lightbox__body {
      padding: var(--s-6);
    }
    .lightbox__title {
      font-size: 24px;
    }
  }
</style>

<script>
  function closeLightbox() {
    const lb = document.querySelector<HTMLElement>('[data-lightbox]');
    if (lb) {
      lb.style.animation = 'lb-out 200ms var(--ease-out) forwards';
      setTimeout(() => lb.remove(), 200);
      document.body.style.overflow = '';
    }
  }

  // Wire up close buttons.
  document.querySelectorAll<HTMLElement>('[data-lightbox-close]').forEach((b) => {
    b.addEventListener('click', closeLightbox);
  });

  // ESC to close.
  const escListener = (e: KeyboardEvent) => {
    if (e.key === 'Escape') closeLightbox();
  };
  document.addEventListener('keydown', escListener);

  // Lock scroll.
  document.body.style.overflow = 'hidden';

  // Trap focus.
  const panel = document.querySelector<HTMLElement>('[data-lightbox-panel]');
  if (panel) {
    const closeBtn = panel.querySelector<HTMLElement>('[data-lightbox-close]');
    closeBtn?.focus();
  }

  // Cleanup on unmount (when Astro swaps the page).
  document.addEventListener(
    'astro:before-swap',
    () => {
      document.body.style.overflow = '';
      document.removeEventListener('keydown', escListener);
    },
    { once: true },
  );

  // Inject out animation.
  const style = document.createElement('style');
  style.textContent = `@keyframes lb-out { to { opacity: 0; } }`;
  document.head.appendChild(style);
</script>