---
const links = [
  { href: '/', label: 'Home' },
  { href: '/posts', label: 'Posts' },
  { href: '/now', label: 'Now' },
  { href: '/about', label: 'About' },
  { href: '/colophon', label: 'Colophon' },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="nav" data-nav>
  <div class="nav__inner container-wide">
    <a href="/" class="nav__brand" aria-label="首页">
      <span class="nav__brand-mark">小兔头</span>
      <span class="nav__brand-en">weichao.ren</span>
    </a>

    <nav class="nav__links" aria-label="主导航">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={['nav__link', { 'is-active': isActive(l.href) }]}
            aria-current={isActive(l.href) ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <button
      type="button"
      class="nav__toggle"
      aria-label="打开菜单"
      aria-expanded="false"
      data-nav-toggle
    >
      <span></span><span></span>
    </button>
  </div>

  <div class="nav__mobile" data-nav-mobile hidden>
    {
      links.map((l) => (
        <a
          href={l.href}
          class:list={['nav__mobile-link', { 'is-active': isActive(l.href) }]}
        >
          {l.label}
        </a>
      ))
    }
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    background: rgba(245, 244, 237, 0.78);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--color-warm-border);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }
  .nav__brand {
    display: flex;
    align-items: baseline;
    gap: var(--s-3);
    color: var(--color-warm-text);
    font-weight: 500;
  }
  .nav__brand:hover {
    text-decoration: none;
  }
  .nav__brand-mark {
    font-family: var(--font-serif);
    font-size: 19px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .nav__brand-en {
    font-size: 13px;
    color: var(--color-warm-text-dim);
    font-family: var(--font-mono);
  }
  .nav__links {
    display: flex;
    gap: var(--s-6);
  }
  .nav__link {
    color: var(--color-warm-text-muted);
    font-size: 14px;
    padding: 6px 2px;
    transition: color var(--t-fast) var(--ease-out);
    position: relative;
  }
  .nav__link:hover {
    color: var(--color-warm-text);
    text-decoration: none;
  }
  .nav__link.is-active {
    color: var(--color-warm-text);
  }
  .nav__link.is-active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    background: var(--color-terracotta);
    border-radius: 2px;
  }

  .nav__toggle {
    display: none;
    width: 40px;
    height: 40px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
  }
  .nav__toggle span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--color-warm-text);
    transition: transform 200ms;
  }

  .nav__mobile {
    display: flex;
    flex-direction: column;
    padding: var(--s-3) var(--s-6) var(--s-5);
    background: var(--color-ivory);
    border-bottom: 1px solid var(--color-warm-border);
  }
  .nav__mobile-link {
    padding: var(--s-3) 0;
    color: var(--color-warm-text);
    font-size: 17px;
    border-bottom: 1px solid var(--color-warm-border);
  }
  .nav__mobile-link.is-active {
    color: var(--color-terracotta);
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none;
    }
    .nav__toggle {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const mobile = document.querySelector<HTMLElement>('[data-nav-mobile]');
  if (toggle && mobile) {
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      mobile.hidden = open;
    });
  }

  // Close mobile menu when a link is tapped.
  mobile?.querySelectorAll('a').forEach((a: HTMLAnchorElement) =>
    a.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      if (mobile) mobile.hidden = true;
    }),
  );
</script>