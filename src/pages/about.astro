---
// Pre-render at build time → ships as a static asset, served from CDN.
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';

const timeline = [
  { year: 'root', text: '出生于南方，长在北京。' },
  { year: 'study', text: '念了个跟代码没什么关系的本科。' },
  { year: '2010-2014', text: '在两家门户系互联网公司做 iOS 入门。' },
  { year: '2014-2017', text: '在一家汽车互联网公司做编辑器、UI 框架、视频内核。' },
  { year: '2017-2024', text: '在某家科技公司做 iOS 基础架构、隐私检测、LLVM 工具链，前后八年。' },
  { year: '2024', text: '离开职场。开始想清楚下一步。' },
  { year: '2025', text: '去了 30 天雪季、5 次潜水、2 次阳朔攀岩。' },
  { year: '2026', text: '重建个人站。在 AI / 编译 / 创业之间选择。' },
];
---

<BaseLayout
  seo={{
    title: 'About',
    description: 'lazy，做过 Swift 编译器、LLVM 后端、隐私检测相关工作。',
  }}
>
  <article class="about">
    <div class="container container-narrow">
      <header class="about__head reveal">
        <p class="eyebrow">About</p>
        <h1 class="about__title serif">我是谁</h1>
      </header>

      <div class="about__body reveal">
        <p>
          lazy。前 iOS / LLVM 工程师，做过编译器、LLVM 后端、隐私检测相关工作，现在做独立开发者。
        </p>
        <p>
          读书专业跟代码没什么关系，毕业后误打误撞进了互联网。
          前十年在几家互联网公司做 iOS，从客户端到 LLVM 工具链到隐私检测相关工作，
          前后八年做底层。
        </p>
        <p>
          2024 年离开职场，开始认真想：接下来 10 年要做什么？
          是回大厂做 AI infra，还是跳出去做 AI 应用，
          还是做点别的什么？这个问题到现在还没答案。
        </p>
        <p>
          喜欢滑雪、潜水、攀岩、公路旅行。喜欢写代码，
          也喜欢写代码之外的东西 —— 这就是为什么有这个站。
        </p>
      </div>

      <section class="about__timeline">
        <h2 class="about__subtitle serif reveal">时间线</h2>
        <ol class="about__list">
          {timeline.map((t, i) => (
            <li class="about__row reveal" style={`--i: ${i};`}>
              <span class="about__year">{t.year}</span>
              <span class="about__text">{t.text}</span>
            </li>
          ))}
        </ol>
      </section>

      <section class="about__contact reveal">
        <h2 class="about__subtitle serif">联系</h2>
        <ul class="about__links">
          <li><strong>Email：</strong><a href="mailto:hi@weichao.ren">hi@weichao.ren</a></li>
          <li><strong>GitHub：</strong><a href="https://github.com/toolazytoname" rel="noopener" target="_blank">toolazytoname</a></li>
          <li><strong>X：</strong><a href="https://x.com/toolazytoname" rel="noopener" target="_blank">@toolazytoname</a></li>
        </ul>
      </section>
    </div>
  </article>
</BaseLayout>

<style>
  .about {
    padding: var(--s-20) 0 var(--s-24);
    background: var(--color-parchment);
    min-height: 80vh;
  }
  .about__head {
    margin-bottom: var(--s-12);
    padding-bottom: var(--s-6);
    border-bottom: 1px solid var(--color-warm-border);
  }
  .about__title {
    font-size: clamp(48px, 6vw, 72px);
    margin: var(--s-3) 0 0;
    color: var(--color-warm-text);
    letter-spacing: -0.02em;
  }
  .about__body {
    color: var(--color-warm-text-muted);
    font-size: 18px;
    line-height: 1.75;
    margin-bottom: var(--s-16);
  }
  .about__body p {
    margin: 0 0 var(--s-5);
  }
  .about__timeline {
    margin-bottom: var(--s-16);
  }
  .about__subtitle {
    font-size: 28px;
    margin: 0 0 var(--s-6);
    color: var(--color-warm-text);
  }
  .about__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .about__row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: var(--s-6);
    padding: var(--s-4) 0;
    border-top: 1px solid var(--color-warm-border);
    transition-delay: calc(var(--i, 0) * 60ms);
  }
  .about__row:last-child {
    border-bottom: 1px solid var(--color-warm-border);
  }
  .about__year {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-warm-text-dim);
    padding-top: 4px;
  }
  .about__text {
    color: var(--color-warm-text);
    line-height: 1.65;
  }
  .about__contact ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .about__contact li {
    padding: var(--s-3) 0;
    border-top: 1px solid var(--color-warm-border);
  }
  .about__contact li:last-child {
    border-bottom: 1px solid var(--color-warm-border);
  }
  .about__contact strong {
    display: inline-block;
    width: 80px;
    color: var(--color-warm-text-dim);
    font-weight: 500;
  }
  @media (max-width: 600px) {
    .about__row { grid-template-columns: 1fr; gap: var(--s-1); }
  }
</style>