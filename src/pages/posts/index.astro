---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { postSlug } from '@lib/permalink';

const all = (await getCollection('posts')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout
  seo={{
    title: 'Posts',
    description: '从 2016 到现在的所有文章，按时间倒序。',
  }}
>
  <section class="posts">
    <div class="container">
      <header class="posts__head reveal">
        <p class="eyebrow">Posts · 文章</p>
        <h1 class="posts__title serif">{all.length} 篇</h1>
        <p class="posts__lede">
          从 2016 到现在的所有文章，按时间倒序。
        </p>
      </header>

      <ol class="posts__list">
        {all.map((entry) => {
          const dateStr = entry.data.date.toISOString().slice(0, 10);
          const cats = Array.isArray(entry.data.categories) ? entry.data.categories : [entry.data.categories];
          const primaryCat = (cats[0] ?? '').toString().trim() || 'uncategorized';
          const href = '/' + postSlug(entry.id, entry.data) + '/';
          return (
            <li class="posts__item reveal">
              <a href={href} class="posts__link">
                <div class="posts__meta">
                  <span class="posts__tag">{primaryCat}</span>
                  <time datetime={dateStr}>{dateStr}</time>
                </div>
                <h2 class="posts__heading serif">{entry.data.title}</h2>
                {entry.data.summary && (
                  <p class="posts__summary">{entry.data.summary}</p>
                )}
                <div class="posts__tags">
                  {entry.data.tags.map((t) => (
                    <span class="posts__chip">#{t}</span>
                  ))}
                </div>
              </a>
            </li>
          );
        })}
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .posts {
    padding: var(--s-20) 0 var(--s-24);
    background: var(--color-parchment);
    min-height: 80vh;
  }
  .posts__head {
    margin-bottom: var(--s-12);
    max-width: 720px;
  }
  .posts__title {
    font-size: clamp(48px, 6vw, 72px);
    margin: var(--s-3) 0 var(--s-4);
    color: var(--color-warm-text);
    letter-spacing: -0.02em;
  }
  .posts__lede {
    color: var(--color-warm-text-muted);
    font-size: 17px;
    margin: 0;
  }
  .posts__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .posts__item {
    border-top: 1px solid var(--color-warm-border);
  }
  .posts__item:last-child {
    border-bottom: 1px solid var(--color-warm-border);
  }
  .posts__link {
    display: block;
    padding: var(--s-6) 0;
    color: inherit;
    text-decoration: none;
    transition: color 200ms var(--ease-out);
  }
  .posts__link:hover {
    text-decoration: none;
  }
  .posts__meta {
    display: flex;
    gap: var(--s-3);
    align-items: center;
    margin-bottom: var(--s-2);
  }
  .posts__tag {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 980px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    font-weight: 500;
    background: rgba(201, 100, 66, 0.15);
    color: var(--color-terracotta);
  }
  .posts__meta time {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-warm-text-dim);
  }
  .posts__heading {
    font-size: clamp(24px, 3vw, 32px);
    margin: 0 0 var(--s-3);
    color: var(--color-warm-text);
    line-height: 1.2;
    transition: color 200ms;
  }
  .posts__link:hover .posts__heading {
    color: var(--color-terracotta);
  }
  .posts__summary {
    margin: 0 0 var(--s-3);
    color: var(--color-warm-text-muted);
    font-size: 15px;
    line-height: 1.6;
    max-width: 720px;
  }
  .posts__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .posts__chip {
    font-size: 11px;
    color: var(--color-warm-text-dim);
    font-family: var(--font-mono);
  }
</style>